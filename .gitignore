!outputs/**/summary.md

# Models: keep model result folders visible, but ignore heavy artifacts
models/**/checkpoints/
models/**/*.pt
models/**/*.pth
models/**/*.ckpt
models/**/*.bin
models/**/*.onnx

# Ignore specific large file types that might appear anywhere
*.pt
*.pth
*.ckpt
*.gdf
*.mat