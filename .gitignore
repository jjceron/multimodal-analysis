# --- Project Specific ---

# Ignore all raw/processed data
data/

# Outputs: track benchmark results (json, csv), ignore plots and logs
outputs/**/plots/
outputs/**/*.png
outputs/**/*.log

# Ignore other datasets (only modma_db tracked)
outputs/models/adhd_db/
outputs/models/mdd_db/

# Models: keep model result folders visible, but ignore heavy artifacts
models/**/checkpoints/
models/**/*.pt
models/**/*.pth
models/**/*.ckpt
models/**/*.bin
models/**/*.onnx


# Optuna: keep the structure and summary files, but ignore all trial artifacts
models/hbn_db/optuna/*
!models/hbn_db/optuna/*/
!models/hbn_db/optuna/**/*.csv
!models/hbn_db/optuna/**/*.json

# Ignore specific large file types that might appear anywhere
*.pt
*.pth
*.ckpt
*.gdf
*.mat

